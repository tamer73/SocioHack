# ── Python ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# ── Local secrets / environment ──────────────────────────────────────
# Never commit API keys or proxy endpoints. Keep credentials in env vars
# or a file outside the repo (see README "Authentication").
*.env
.env*
.secrets*
*secret*

# ── Hydra run dirs ───────────────────────────────────────────────────
outputs/
multirun/
.hydra/

# ── Per-scenario configs auto-generated by the batch train scripts ────
# (the base configs historical.yaml / synthetic.yaml / fictional.yaml /
#  historical_merged.yaml are tracked; the generated ones are not)
configs/*_historical.yaml
configs/*_synthetic.yaml
configs/*_fictional.yaml

# ── Training artifacts (written to the working dir per scenario) ──────
loopholes_*.json
rollouts_*.csv
llm_debug_*.csv
llm_debug_*.log

# ── Result / evaluation output dirs ──────────────────────────────────
rl_results_*/
results/
# eval outputs (written into MINED_DIR, which may be the repo root or eval/)
eval_*_results.json
eval_*_cache.json
eval_*_summary.md
eval_*_summary.csv

# ── Experiment tracking & checkpoints ────────────────────────────────
wandb/
checkpoints/
*.ckpt

# ── Misc ─────────────────────────────────────────────────────────────
*.log
.DS_Store
